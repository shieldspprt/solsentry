# --- Supabase API Configuration ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Direct PostgreSQL Shared Pooler Connection Details ---
SUPABASE_PASSWORD=your-database-password
SUPABASE_DB_HOST=your-region.pooler.supabase.com
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres.your-project-ref
SUPABASE_DIRECT_URL=postgresql://postgres.your-project-ref:password@your-region.pooler.supabase.com:5432/postgres

# --- Helius (Solana RPC — mainnet for live holder concentration + epoch data) ---
# Used by grounded-metrics (getTokenLargestAccounts) and the epoch card.
# Without a key, code falls back to the public RPC (lower rate limits).
NEXT_PUBLIC_HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your-helius-api-key
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your-helius-api-key
HELIUS_API_KEY=your-helius-api-key

# --- Jupiter Token API (market-integrity factor) ---
# Grounds the Market Integrity factor: Jupiter's organic-activity score, the
# organic vs bot/arbitrage volume split, and top-holder concentration for each
# protocol's governance token. Get one at https://portal.jup.ag.
# Without a key the code falls back to lite-api.jup.ag (same data, lower limits).
JUPITER_DEV_KEY=your-jupiter-portal-key

# --- GitHub (developer-activity factor) ---
# Optional but strongly recommended. Unauthenticated GitHub allows 60 req/hour
# per IP; scoring all nine protocols costs ~36. Without a token the developer
# activity factor will intermittently report as unmeasured. A fine-grained
# token with public read access is sufficient — no scopes needed.
GITHUB_TOKEN=your-github-token

# --- Web Push (liquidation alerts) ---
# Generate with:  npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:alerts@your-domain.com

# --- App & Network Settings ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- Solana x402 Micropayments ---
X402_RECIPIENT_WALLET=your-solana-wallet-address
X402_NETWORK=devnet
