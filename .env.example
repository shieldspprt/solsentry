# --- Supabase API Configuration ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Direct PostgreSQL Shared Pooler Connection Details ---
SUPABASE_PASSWORD=your-database-password
SUPABASE_DB_HOST=your-region.pooler.supabase.com
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres.your-project-ref
SUPABASE_DIRECT_URL=postgresql://postgres.your-project-ref:password@your-region.pooler.supabase.com:5432/postgres

# --- Helius (Solana RPC — mainnet for live holder concentration + epoch data) ---
# Used by grounded-metrics (getTokenLargestAccounts) and the epoch card.
# Without a key, code falls back to the public RPC (lower rate limits).
NEXT_PUBLIC_HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your-helius-api-key
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your-helius-api-key
HELIUS_API_KEY=your-helius-api-key

# --- Web Push (liquidation alerts) ---
# Generate with:  npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:alerts@your-domain.com

# --- App & Network Settings ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- Solana x402 Micropayments ---
X402_RECIPIENT_WALLET=your-solana-wallet-address
X402_NETWORK=devnet
